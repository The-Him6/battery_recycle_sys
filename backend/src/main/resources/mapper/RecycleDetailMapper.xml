<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.battery.recycle.mapper.RecycleDetailMapper">
    
    <resultMap id="BaseResultMap" type="com.battery.recycle.entity.RecycleDetail">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="battery_type_id" property="batteryTypeId"/>
        <result column="battery_count" property="batteryCount"/>
        <result column="points" property="points"/>
        <result column="create_time" property="createTime"/>
    </resultMap>
    
    <select id="getById" resultMap="BaseResultMap">
        SELECT * FROM recycle_detail WHERE id = #{id}
    </select>
    
    <select id="listByOrderId" resultMap="BaseResultMap">
        SELECT * FROM recycle_detail WHERE order_id = #{orderId}
    </select>
    
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO recycle_detail (order_id, battery_type_id, battery_count, points)
        VALUES (#{orderId}, #{batteryTypeId}, #{batteryCount}, #{points})
    </insert>
    
    <insert id="batchInsert">
        INSERT INTO recycle_detail (order_id, battery_type_id, battery_count, points)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.orderId}, #{item.batteryTypeId}, #{item.batteryCount}, #{item.points})
        </foreach>
    </insert>
    
    <delete id="deleteByOrderId">
        DELETE FROM recycle_detail WHERE order_id = #{orderId}
    </delete>
    
</mapper>

